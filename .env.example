# =====================================================
#  LinkedOut Pro — Environment Variables
#  Copy this to .env and fill in your real values
# =====================================================

# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# JWT Secret — generate a strong random string
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ---- GOOGLE GEMINI API ----
# Get your key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ---- LINKEDIN OAUTH ----
# Register your app at: https://www.linkedin.com/developers/apps
# Required scopes: openid, profile, email, w_member_social
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:3000/api/auth/linkedin/callback

# ---- DATABASE (Supabase — used in production) ----
# Create a free project at: https://supabase.com
# Go to Project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ---- SUPABASE STORAGE ----
SUPABASE_STORAGE_BUCKET=post-images

# ---- LOCAL DEV DATABASE (SQLite — ignored if Supabase is configured) ----
DB_PATH=./data/linkedoutpro.db

# ---- FILE UPLOADS (local dev only) ----
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ---- CRON SECURITY ----
# Secret token GitHub Actions uses to call /api/cron/trigger
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_cron_secret_here
